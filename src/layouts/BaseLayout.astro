---
import Globe from '@/components/Globe.astro';
import PlausibleAnalytics from '@/components/PlausibleAnalytics.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import '@fontsource/geist-sans/400.css';
import '@fontsource/geist-sans/500.css';
import { ClientRouter } from 'astro:transitions';

import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const title = Astro.props.title ? `${Astro.props.title} | rayenhamza.me` : 'rayenhamza.me';
const description = Astro.props.description ?? 'Student, software engineer, OSS enthusiast.';

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="rayenhamza.me" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

 

    <meta name="apple-mobile-web-app-title" content="Rayen Hamza" />
    <meta name="application-name" content="Rayen Hamza" />
    <meta name="theme-color" content="#0a0a0a" />

    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=3" sizes="180x180" />
    <link rel="icon" href="/favicon-96x96.png?v=3" sizes="96x96" type="image/png" />
    <link rel="manifest" href="/site.webmanifest?v=3" />
    <link rel="shortcut icon" href="/favicon.ico?v=3" />
    <link rel="canonical" href={canonical} />

    <PlausibleAnalytics />
    <ClientRouter />
    <style>
      @view-transition {
        navigation: auto;
      }

      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation: none;
      }
    </style>
  </head>
  <body
    class="relative flex min-h-screen flex-col bg-neutral-950 lowercase text-white antialiased sm:px-0"
  >
    <!-- Dot grid background overlay -->
    <div class="bg-dots pointer-events-none fixed inset-0 z-0" transition:persist transition:animate="none"></div>

    <SiteHeader />
    <main class="container relative z-10 mt-12 overflow-hidden rounded-3xl border border-neutral-700/40 pb-6" transition:animate="fade">
      <!-- Marching ants border -->
      <!-- <svg class="pointer-events-none absolute inset-0 z-10 h-full w-full" aria-hidden="true">
        <rect
          class="marching-ants"
          x="1" y="1"
          width="calc(100% - 2px)" height="calc(100% - 2px)"
          rx="23"
          fill="none"
          stroke="rgba(82,82,82,0.7)"
          stroke-width="1.5"
        />
      </svg> -->
      <!-- Breath pulse border -->
      <!-- <svg class="pointer-events-none absolute inset-0 z-10 h-full w-full" aria-hidden="true">
        <rect
          class="breath-pulse"
          x="1" y="1"
          width="calc(100% - 2px)" height="calc(100% - 2px)"
          rx="23"
          fill="none"
          stroke-width="1.5"
        />
      </svg> -->
      <!-- Radar sweep border -->
      <!-- <svg class="pointer-events-none absolute inset-0 z-10 h-full w-full" style="overflow: visible;" aria-hidden="true">
        <rect
          class="radar-track"
          x="1" y="1"
          width="calc(100% - 2px)" height="calc(100% - 2px)"
          rx="23"
          fill="none"
          stroke-width="1.5"
        />
        <defs>
          <mask id="dash-mask">
            <rect
              class="radar-mask"
              x="1" y="1"
              width="calc(100% - 2px)" height="calc(100% - 2px)"
              rx="23"
              fill="none"
              stroke="white"
              stroke-width="2"
            />
          </mask>
        </defs>
        <foreignObject width="200%" height="200%" x="-50%" y="-50%" mask="url(#dash-mask)">
          <div class="radar-sweep"></div>
        </foreignObject>
      </svg> -->
      <!-- Star border (traveling light dot) -->
      <div class="star-border pointer-events-none absolute inset-0 z-10 rounded-3xl">
        <div class="star-border-spinner"></div>
      </div>
      <slot />
    </main>
    <footer class="relative z-10 py-8 text-center text-xs tracking-tighter text-neutral-400">
      <p>&copy; 2026 Rayen Hamza</p>
    </footer>
    <div
      class="pointer-events-none fixed inset-x-0 bottom-0 z-20 h-16 w-full bg-gradient-to-t from-neutral-950 to-transparent"
      transition:persist
      transition:animate="none"
    >
    </div>

    <Globe />


  </body>
</html>
