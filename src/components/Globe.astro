<canvas
  class="pointer-events-none fixed -left-1/4 -top-16 -z-10 size-[1500px] opacity-0 transition-opacity duration-1000"
  height="1500"
  width="1500"
  id="globe"
  transition:persist
  transition:animate="none"></canvas>

<script>
  import createGlobe from 'cobe';

  const w = window as any;

  if (!w.__globeInit) {
    w.__globeInit = true;
    w.__globePhi = w.__globePhi ?? 0;

    const canvas = document.getElementById('globe') as HTMLCanvasElement;
    if (canvas) {
      createGlobe(canvas, {
        devicePixelRatio: 1,
        width: 1500,
        height: 1500,
        phi: 0,
        theta: 0,
        diffuse: 1.2,
        dark: 1,
        scale: 1,
        mapSamples: 10000,
        mapBrightness: 6,
        markers: [],
        offset: [0, 0],
        baseColor: [1, 1, 1],
        glowColor: [1, 1, 1],
        markerColor: [0.1, 0.8, 1],
        onRender: (state) => {
          state.phi = w.__globePhi;
          w.__globePhi += 0.001;
        }
      });

      // Fade in once via inline style — no replayable CSS animation
      requestAnimationFrame(() => canvas.style.opacity = '0.1');
    }
  }
</script>
