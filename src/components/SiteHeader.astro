---
import PencilLineIcon from '@lucide/astro/icons/pencil-line';
import SparklesIcon from '@lucide/astro/icons/sparkles';
import SquareMousePointerIcon from '@lucide/astro/icons/square-mouse-pointer';
import folderClosedIcon from '@lucide/astro/icons/folder-closed';

const links = [
  {
    icon: SquareMousePointerIcon,
    label: 'Home',
    path: '/'
  },{
    icon : folderClosedIcon,
    label : 'Projects',
    path : '/projects'
},
  {
    icon: SparklesIcon,
    label: 'Gems',
    path: '/gems'
  },
  {
    icon: PencilLineIcon,
    label: 'Blog',
    path: '/blog'
  }
];
---

<div class="fixed inset-x-0 top-0 z-50 flex justify-center pt-4 px-4 pointer-events-none" transition:persist transition:animate="none">
  <nav class="pointer-events-auto rounded-full border border-neutral-800 bg-neutral-900/80 px-2 py-1.5 shadow-2xl shadow-black/50 backdrop-blur-md">
    <ul class="flex flex-row gap-1 text-sm text-neutral-400">
      {
        links.map((link) => (
          <li>
            <a
              href={link.path}
              target={link.path.startsWith('/') ? undefined : '_blank'}
              class:list={[
                'flex items-center gap-1.5 rounded-full px-3 py-1.5 transition-[color,background-color,transform] active:scale-95',
                link.path === Astro.url.pathname ||
                link.path === Astro.url.pathname.replace(/\/$/, '')
                  ? 'bg-white/10 text-white'
                  : 'hover:bg-white/5 hover:text-neutral-200'
              ]}
            >
              <link.icon stroke-width="2" class="size-4" />
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>
