---
import { Image } from 'astro:assets';
import TorusKnot from '@/components/TorusKnot.astro';

interface Props {
  name: string;
  subtitle: string;
  avatarImage: ImageMetadata;
}

const { name, subtitle, avatarImage } = Astro.props;
---

<section class="relative pt-6">
  <!-- Float knot on desktop so content can flow under it -->
  <div class="hidden md:block float-right ml-6 -mt-1">
    <TorusKnot />
  </div>

  <div class="space-y-6">
    <!-- Avatar -->
    <div class="avatar-ring w-24 h-24 sm:w-28 sm:h-28 rounded-3xl overflow-hidden border border-neutral-800 shadow-2xl">
      <Image
        class="h-full w-full object-cover"
        src={avatarImage}
        draggable="false"
        loading="eager"
        format="webp"
        quality={90}
        width={384}
        height={384}
        alt="Profile photo"
      />
    </div>

    <!-- Name + Subtitle -->
    <div class="space-y-1">
      <h1 class="text-2xl font-medium tracking-tighter sm:text-3xl">{name}</h1>
      <p class="text-sm text-neutral-500">{subtitle}</p>
    </div>

    <slot />
  </div>
</section>
