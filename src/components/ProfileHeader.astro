---
import { Image } from 'astro:assets';

interface Props {
  name: string;
  subtitle: string;
  avatarImage: ImageMetadata;
  coverImage?: ImageMetadata;
}

const { name, subtitle, avatarImage, coverImage } = Astro.props;
---

<section class="flex flex-col pt-6">
  <!-- Cover Banner -->
  <div class="relative -mx-4 h-32 overflow-hidden rounded-b-lg sm:h-44">
    {
      coverImage ? (
        <Image
          class="h-full w-full object-cover"
          src={coverImage}
          alt=""
          loading="eager"
          densities={[1.5]}
          width={768}
          height={176}
        />
      ) : (
        <div class="h-full w-full bg-transparent" />
      )
    }
  </div>

  <!-- Avatar + Info -->
  <div class="flex flex-col gap-3">
    <div class="relative z-10 -mt-12 ml-2">
      <Image
        class="size-20 rounded-full border-4 border-neutral-950 object-cover sm:size-24 sm:border-[5px]"
        src={avatarImage}
        draggable="false"
        loading="eager"
        format="webp"
        quality={90}
        width={384}
        height={384}
        alt="Profile photo"
      />
    </div>

    <div class="-mt-1">
      <h1 class="text-2xl/6 font-medium tracking-tighter">{name}</h1>
      <p class="text-neutral-500">{subtitle}</p>
    </div>

    <slot />
  </div>
</section>
